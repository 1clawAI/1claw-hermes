# 1Claw credentials
ONECLAW_API_BASE=https://api.1claw.xyz
ONECLAW_VAULT_ID=<your-vault-uuid>
ONECLAW_AGENT_API_KEY=ocv_...          # human operator key for agent registration
ONECLAW_MCP_URL=https://mcp.1claw.xyz/mcp
ONECLAW_MCP_TOKEN=<short-lived-jwt>    # or leave blank to auto-exchange at startup

# Shroud proxy
SHROUD_URL=https://shroud.1claw.xyz/v1
SHROUD_TOKEN=<shroud-bearer-token>
SHROUD_PROVIDER=anthropic              # anthropic | openai | google | mistral | cohere

# Hermes runtime
HERMES_CONFIG_DIR=~/.hermes
