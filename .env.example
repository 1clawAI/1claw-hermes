# 1claw agent credentials
# Run `pnpm bootstrap` to set up automatically, or fill in manually.
# Bootstrap writes ONECLAW_AGENT_ID + ONECLAW_VAULT_ID when the API returns them
# (required for raw `shroud-sidecar`; `pnpm shroud` also auto-appends agent id if missing).
ONECLAW_AGENT_API_KEY=ocv_...
# ONECLAW_AGENT_ID=<uuid>   # set automatically after `pnpm bootstrap complete`

# Optional overrides (only needed in advanced setups):
# ONECLAW_VAULT_ID=<vault-uuid>
# ONECLAW_API_BASE=https://api.1claw.xyz
# ONECLAW_MCP_URL=https://mcp.1claw.xyz/mcp
# SHROUD_URL=https://shroud.1claw.xyz/v1
# SHROUD_TOKEN=<bearer-token>     # defaults to the agent JWT if not set
# SHROUD_PROVIDER=anthropic       # anthropic | openai | google | mistral | cohere — used by createShroudClient() in Node only
#
# Hermes LLM via Shroud sidecar: run shroud-sidecar separately; set ONECLAW_DEFAULT_PROVIDER
# on THAT process (not here). mcp_servers.oneclaw.env does not configure model.base_url.
# If .env lives outside this folder (e.g. cloud: ~/.hermes/hermes-agent/1claw-hermes/.env):
# ONECLAW_ENV_FILE=/full/path/to/.env
# HERMES_CONFIG_DIR=~/.hermes
