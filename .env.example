# 1claw agent credentials
# Run `pnpm bootstrap` to set up automatically, or fill in manually.
# Agent ID and vault are auto-discovered from the key — no extra vars needed.
ONECLAW_AGENT_API_KEY=ocv_...

# Optional overrides (only needed in advanced setups):
# ONECLAW_VAULT_ID=<vault-uuid>
# ONECLAW_API_BASE=https://api.1claw.xyz
# ONECLAW_MCP_URL=https://mcp.1claw.xyz/mcp
# SHROUD_URL=https://shroud.1claw.xyz/v1
# SHROUD_TOKEN=<bearer-token>     # defaults to the agent JWT if not set
# SHROUD_PROVIDER=anthropic       # anthropic | openai | google | mistral | cohere
# HERMES_CONFIG_DIR=~/.hermes
